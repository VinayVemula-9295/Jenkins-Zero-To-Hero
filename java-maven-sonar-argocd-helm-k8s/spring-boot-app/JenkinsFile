pipeline {
    agent none

    environment {
        GIT_REPO_NAME = "Jenkins-Zero-To-Hero"
        GIT_USER_NAME = "VinayVemula-9295"

        SONAR_URL = "http://18.60.156.212:9000"

        DOCKER_IMAGE = "vinayvemula13/ultimate-cicd:${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            agent any

            steps {
                checkout scm
            }
        }

        stage('Build & Test') {

            agent {
                docker {
                    image 'vinayvemula13/maven-vinay-docker-agent:v1'
                    args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
                    reuseNode true
                }
            }

            steps {

                dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {

                    sh 'mvn clean package'

                }

            }

        }

        stage('SonarQube Analysis') {

            agent {
                docker {
                    image 'vinayvemula13/maven-vinay-docker-agent:v1'
                    args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
                    reuseNode true
                }
            }

            steps {

                dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {

                    withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_TOKEN')]) {

                        sh '''
                        mvn sonar:sonar \
                        -Dsonar.login=$SONAR_TOKEN \
                        -Dsonar.host.url=$SONAR_URL
                        '''

                    }

                }

            }

        }

        stage('Docker Build & Push') {

            agent {
                docker {
                    image 'vinayvemula13/maven-vinay-docker-agent:v1'
                    args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
                    reuseNode true
                }
            }

            steps {

                script {

                    dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {

                        sh """
                        docker build -t ${DOCKER_IMAGE} .
                        """

                    }

                    docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {

                        docker.image(DOCKER_IMAGE).push()

                    }

                }

            }

        }

        stage('Update Deployment Manifest') {
                agent any
    environment {
        GIT_REPO_NAME = "Deployment"
        GIT_USER_NAME = "VinayVemula-9295"
    }

    steps {
        dir('deployment-repo') {

            git branch: 'main',
                credentialsId: 'github',
                url: "https://github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git"

            withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {

                sh """
                    git config --global user.email "vinayvemula13@outlook.com"
                    git config --global user.name "VinayVemula-9295"

                    sed -i 's#image: vinayvemula13/ultimate-cicd:.*#image: vinayvemula13/ultimate-cicd:${BUILD_NUMBER}#g' \
                    spring-boot-app-manifests/deployment.yml

                    git add spring-boot-app-manifests/deployment.yml

                    git commit -m "Update image tag to ${BUILD_NUMBER}" || true

                    git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git HEAD:main
                """
            }
        }
    }
}

}
}
